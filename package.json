{
  "name": "targetj",
  "version": "1.0.251",
  "description": "TargetJS: JavaScript UI framework where state is a destination and code order defines the UI sequence",
  "keywords": ["targetjs"],
  "type": "module",
  "main": "./Export.js",
  "module": "./Export.js",
  "exports": {
    ".": "./Export.js",
    "./Export.js": "./Export.js"
  },
  "homepage": "https://targetjs.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/livetrails/targetjs.git"
  },
  "bugs": {
    "url": "https://github.com/livetrails/targetjs/issues"
  },
  "contributors": [
    {
      "name": "Ahmad Wasfi"
    }
  ],
  "scripts": {
    "prod": "webpack --config webpack.config.cjs --mode production && gzip -kf ./dist/targetjs.js",
    "dev": "webpack --config webpack.config.cjs --mode development",
    "build": "babel src --out-dir build"
  },
  "files": [
    "Export.js",
    "build/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@babel/cli": "^7.25.6",
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.0",
    "@babel/preset-env": "^7.25.4",
    "babel-loader": "^9.1.0",
    "eslint-webpack-plugin": "^4.2.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}